# ===== 非機密設定（AIに見せてOK） =====
# 機密情報は .env.secrets に分離してください

# DB
DATABASE_URL=sqlite:///./data/assetbridge.db

# LLM モデル選択（APIキーは .env.secrets へ）
LLM_MODEL=claude-sonnet-4-6

# Discord チャンネルID（Token は .env.secrets へ）
DISCORD_CHANNEL_ID=123456789012345678

# サービス設定
API_HOST=0.0.0.0
API_PORT=8000
MCP_HOST=0.0.0.0
MCP_PORT=8001
WEB_PORT=3000
