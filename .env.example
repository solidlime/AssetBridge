# ===== AssetBridge 設定テンプレート =====
# このファイルをコピーして ~/.assetbridge/.env を作成してください:
#   python scripts/setup_secrets.py
#
# .env は ~/.assetbridge/ に隔離されるため AI からは読み取れません。

# ===== マネーフォワード for 住信SBI銀行 =====
MF_EMAIL=your_email@example.com
MF_PASSWORD=your_password
MF_TOTP_SEED=                    # TOTP 2FA シード（オプション）

# ===== Discord =====
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=123456789012345678

# ===== LLM =====
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=...

# ===== 外部データソース =====
NEWS_API_KEY=your_newsapi_key

# ===== セキュリティ =====
API_KEY=your_api_key_for_fastapi
ENCRYPTION_KEY=                  # 空欄 → 起動時に自動生成

# ===== DB =====
DATABASE_URL=sqlite:///./data/assetbridge.db

# ===== サービス設定 =====
API_HOST=0.0.0.0
API_PORT=8000
MCP_HOST=0.0.0.0
MCP_PORT=8001
WEB_PORT=3000
