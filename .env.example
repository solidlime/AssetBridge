# ====================================
# AssetBridge 環境変数設定テンプレート
# ====================================
# ローカル環境: ~/.assetbridge/.env にコピーして使用
# Docker環境: このファイルを .env にコピーして docker-compose.yml で読み込み

# -------------------------------------
# MoneyForward SBI Bank 認証
# -------------------------------------
MF_EMAIL=your_email@example.com
MF_PASSWORD=your_password
MF_TOTP_SEED=                    # TOTP 2FA シード（オプション）

# -------------------------------------
# Discord Bot 設定
# -------------------------------------
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=123456789012345678

# -------------------------------------
# LLM 設定
# -------------------------------------
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=...

# -------------------------------------
# 外部データソース
# -------------------------------------
NEWS_API_KEY=your_newsapi_key

# -------------------------------------
# セキュリティ
# -------------------------------------
API_KEY=your_api_key_for_fastapi
ENCRYPTION_KEY=                  # 空欄 → 起動時に自動生成

# -------------------------------------
# データベース
# -------------------------------------
# ローカル: sqlite:///./data/assetbridge_v2.db
# Docker: /app/data/assetbridge_v2.db (docker-compose.yml で自動設定)
DATABASE_URL=./data/assetbridge_v2.db

# -------------------------------------
# サービス設定（ローカル環境用）
# -------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
MCP_HOST=0.0.0.0
MCP_PORT=8001
WEB_PORT=3000

# -------------------------------------
# サービス間通信（Docker 環境では自動設定）
# -------------------------------------
API_URL=http://localhost:8000
NODE_ENV=production

# -------------------------------------
# Playwright 設定（Docker 環境では自動設定）
# -------------------------------------
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
