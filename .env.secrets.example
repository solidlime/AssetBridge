# ===== 機密情報（AIに見せない） =====
# セットアップ: python scripts/setup_secrets.py
# 保存先: ~/.assetbridge/.env.secrets  ← プロジェクト外に隔離
# Git管理外・AIアシスタントへの共有禁止（Claude Code のスコープ外）

# マネーフォワード for 住信SBI銀行
MF_EMAIL=your_email@example.com
MF_PASSWORD=your_password
MF_TOTP_SEED=                    # TOTP 2FA シード（オプション）

# Discord
DISCORD_TOKEN=your_discord_bot_token

# LLM APIキー（使うものだけ設定）
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=...

# 外部データソース
NEWS_API_KEY=your_newsapi_key

# セキュリティ
API_KEY=your_api_key_for_fastapi
ENCRYPTION_KEY=                  # 空欄 → 起動時に自動生成
