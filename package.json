{
  "name": "assetbridge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config packages/db/drizzle.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "drizzle-kit": "^0.30.0",
    "turbo": "^2",
    "typescript": "^5"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "tsx": "^4.21.0",
    "yahoo-finance2": "^3.13.2"
  },
  "pnpm": {
    "overrides": {
      "bun-types": "1.3.11"
    }
  }
}
